  as (
    with ranked as (
    select
        *,
        row_number() over (
            partition by machine_id
            order by modifiedon desc nulls last
        ) as rn
    from erp_raw.machines
    where machine_type in ('INJECTION_MOULDING', 'CNC', 'HEATING')
)

